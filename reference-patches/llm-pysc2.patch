+      # World Commander — analytic one-shot calibration. Replaces the quarter-step
+      # iteration that never converged on SC2 4.10: ~0.5-world-unit fine steps are
+      # below the camera's move granularity, so unit_f froze just outside the tight
+      # +-3% window. Instead compute the EXACT world-offset correction from the
+      # on-screen error in one shot (screen px -> world units via
+      # SCREEN_WORLD_GRID/size_screen), and accept once within a realistic tolerance
+      # (the camera grid is ~size_screen/SCREEN_WORLD_GRID px per world unit, so +-3%
+      # is unreachable) or after a few corrections (robust to a moving combat unit).
+      # The offset is then analytically correct, so the world->screen mapping used
+      # for clicks is right even when residual centering is approximate.
+      err_x = unit_f.x - self.size_screen / 2
+      err_y = unit_f.y - self.size_screen / 2
+      tol = self.size_screen * 0.06
+      world_per_px = SCREEN_WORLD_GRID / self.size_screen
+      self._wcb_calib_n = getattr(self, '_wcb_calib_n', 0) + 1
+      if abs(err_x) <= tol and abs(err_y) <= tol:
+        self.world_xy_calibration = True
+      else:
+        self.world_x_offset += err_x * world_per_px
+        self.world_y_offset -= err_y * world_per_px
+        self.world_xy_calibration = self._wcb_calib_n >= 4
