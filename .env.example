# Model endpoint (OpenAI-compatible, e.g. vLLM). Differs per machine — see README.
WCB_BASE_URL=http://localhost:8000/v1
WCB_API_KEY=EMPTY
WCB_MODEL=Qwen/Qwen3-14B-AWQ

# Arena defaults (each overridable on the CLI)
WCB_GRID=8
WCB_AGENTS=4
WCB_NPCS=4
WCB_TICK_MS=500

# Optional: unlisted GitHub Pages mirror for report.html.
# Create a public repo with an opaque slug, then publish via scripts/publish_report.sh.
# Kept here (gitignored) so the URL is not committed into the open-sourcing repo.
# WCB_REPORT_REPO=yourname/opaque-slug
